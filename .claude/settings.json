{
  "permissions": {
    "allow": [
      "mcp__synthetic-user__consult_director"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python D:/AI/Synthetic/hooks/session_start_handler.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python D:/AI/Synthetic/hooks/stop_handler.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python D:/AI/Synthetic/hooks/pre_tool_use_handler.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python D:/AI/Synthetic/hooks/post_tool_use_handler.py"
          }
        ]
      }
    ]
  }
}
